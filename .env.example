# Twilio Integration Credentials
# Get these from your Twilio Console: https://www.twilio.com/console
TWILIO_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_NUMBER=+1234567890

# Note: The system will automatically fall back to logging in logs/sms_gateway.log
# if these credentials are not set in the environment.
